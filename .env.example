# ============================================
# Laguna Capital — Earnings Reminder Config
# ============================================

# FMP API Key (Ultimate plan)
FMP_API_KEY=your_fmp_api_key_here

# SMTP Configuration for email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Laguna Capital Earnings <your_email@gmail.com>"

# Server port
PORT=3000

# Cron schedule (default: 4:30 PM ET, Monday-Friday)
# Format: minute hour * * day-of-week
CRON_SCHEDULE=30 16 * * 1-5

# Timezone for cron
CRON_TIMEZONE=America/New_York
